{
  "manifest_version": 3,
  "name": "IG Last 3 Posts Tracker",
  "version": "1.0",
  "description": "Shows how many days ago the last 3 Instagram posts were published",
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*/"],
      "js": ["content.js"]
    }
  ]
}
{
  "manifest_version": 3,
  "name": "Instagram Last Post Tracker",
  "version": "1.0.0",
  "description": "Shows how many days since the latest Instagram post.",
  "permissions": [],
  "host_permissions": ["https://www.instagram.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": [
        "content/dom.js",
        "content/time.js",
        "content/ui.js",
        "content/content.js"
      ],
      "css": ["styles.css"]
    }
  ]
}